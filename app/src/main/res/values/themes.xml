<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.OConcurseiro" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@color/brand_primary</item>
        <item name="android:navigationBarColor">@color/surface_background</item>
        <item name="android:windowBackground">@color/brand_primary</item>
    </style>

    <style name="Theme.OConcurseiro.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/brand_primary</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.OConcurseiro</item>
    </style>
</resources>
