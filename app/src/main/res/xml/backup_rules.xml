<?xml version="1.0" encoding="utf-8"?>
<full-backup-content>
    <!-- Inclui o banco local de respostas do usuário (histórico de estudos) -->
    <include domain="database" path="concurseiro.db" />

    <!-- Exclui todos os SharedPreferences (contêm tokens e dados sensíveis) -->
    <exclude domain="sharedpref" path="." />

    <!-- Exclui cache e arquivos temporários -->
    <exclude domain="cache" path="." />
    <exclude domain="external-cache" path="." />
</full-backup-content>
