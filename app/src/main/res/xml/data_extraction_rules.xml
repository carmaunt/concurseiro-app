<?xml version="1.0" encoding="utf-8"?>
<!-- Regras para Android 12+ (API 31+) -->
<data-extraction-rules>
    <cloud-backup>
        <!-- Inclui o banco local de respostas do usuário (histórico de estudos) -->
        <include domain="database" path="concurseiro_db" />

        <!-- Exclui SharedPreferences sensíveis e temporários -->
        <exclude domain="sharedpref" path="guest_usage.xml" />
        <exclude domain="sharedpref" path="androidx.security.crypto.EncryptedSharedPreferences" />

        <!-- Exclui cache -->
        <exclude domain="cache" path="." />
        <exclude domain="external-cache" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Transferência entre dispositivos: inclui histórico de estudos -->
        <include domain="database" path="concurseiro_db" />

        <!-- Exclui dados temporários e credenciais -->
        <exclude domain="sharedpref" path="guest_usage.xml" />
        <exclude domain="sharedpref" path="androidx.security.crypto.EncryptedSharedPreferences" />
        <exclude domain="cache" path="." />
    </device-transfer>
</data-extraction-rules>
